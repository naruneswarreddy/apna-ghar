<% layout('layouts/boilerplate.ejs') %>

<%- include("../includes/navbar.ejs") %>
<%- include("../includes/flash.ejs") %>

<style>
    .error-code{
        font-size:64px;
        font-weight:700;
        letter-spacing:2px;
    }
</style>

<!-- ERROR CARD SECTION -->
<div class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div class="card shadow border-0 p-4 text-center home-card" style="max-width:480px; width:100%;">
        <h1 class="error-code text-danger mb-2">
            <%= err.statusCode || 500 %>
        </h1>
        <h5 class="mb-3 fw-semibold">
            <%= err.message || "Something went wrong" %>
        </h5>
        <p class="text-muted small mb-4">
            The page you are trying to access might not exist or an unexpected error occurred.
        </p>
        <div>
            <a href="/" class="btn btn-pro btn-primary me-2">
                Go Home
            </a>
            <button onclick="history.back()" class="btn btn-pro btn-secondary">
                Go Back
            </button>
        </div>
    </div>
</div>


